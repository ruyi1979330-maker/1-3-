    <LinearLayout
        android:id="@+id/layoutActionButtons"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_marginTop="16dp"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:orientation="horizontal"
        app:layout_constraintTop_toBottomOf="@id/cardTop">

        <Button
            android:id="@+id/btnLaunchCamera"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:text="📷 拍照"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnGallery"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:text="🖼 相册"
            style="?attr/materialButtonOutlinedStyle" />

        <!-- 【新增】定标按钮：只有管理员配置时使用，平时工人可以用它重新框选 -->
        <Button
            android:id="@+id/btnRoiCalibration"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:text="📐 定标"
            style="?attr/materialButtonOutlinedStyle"
            android:textColor="@color/primary_blue"/>

        <ImageButton
            android:id="@+id/btnPresetSettings"
            android:layout_width="64dp"
            android:layout_height="match_parent"
            android:src="@drawable/ic_settings"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="预设配置"
            app:tint="@color/text_secondary" />
    </LinearLayout>
